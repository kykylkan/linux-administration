pipeline {
    agent {
        kubernetes {
            label 'django-build-agent'
            defaultContainer 'docker'
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins
  containers:
  - name: docker
    image: docker:24-dind
    securityContext:
      privileged: true
    tty: true
  - name: python
    image: python:3.12-slim
    command: ['cat']
    tty: true
"""
        }
    }

    environment {
        AWS_REGION      = 'eu-central-1'
        ARGOCD_APP_NAME = 'django-app'
        SKIP_PIPELINE   = 'false'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.IMAGE_TAG = sh(
                        script: 'git rev-parse --short=7 HEAD',
                        returnStdout: true
                    ).trim()
                    env.SKIP_PIPELINE = sh(
                        script: 'git log -1 --pretty=%ae',
                        returnStdout: true
                    ).trim() == 'jenkins@localhost' ? 'true' : 'false'
                }
            }
        }

        stage('Lint & Unit Tests') {
            when {
                expression { env.SKIP_PIPELINE != 'true' }
            }
            steps {
                container('python') {
                    sh '''
                        cd Django/app
                        pip install --no-cache-dir -r requirements.txt
                        python manage.py check
                        python manage.py test
                    '''
                }
            }
        }

        stage('Build Image') {
            when {
                expression { env.SKIP_PIPELINE != 'true' }
            }
            steps {
                sh 'docker build -t $ECR_REPO:$IMAGE_TAG -f Django/Dockerfile Django'
            }
        }

        stage('Push to ECR') {
            when {
                expression { env.SKIP_PIPELINE != 'true' }
            }
            steps {
                sh '''
                    apk add --no-cache aws-cli
                    ECR_REGISTRY="${ECR_REPO%/*}"
                    aws ecr get-login-password --region "$AWS_REGION" \
                      | docker login --username AWS --password-stdin "$ECR_REGISTRY"
                    docker push $ECR_REPO:$IMAGE_TAG
                '''
            }
        }

        stage('Update GitOps image tag') {
            when {
                expression { env.SKIP_PIPELINE != 'true' }
            }
            steps {
                container('python') {
                    withCredentials([usernamePassword(
                        credentialsId: 'git-write-credentials',
                        usernameVariable: 'GIT_USERNAME',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh '''
                            python - <<'PY'
                            from pathlib import Path
                            import os

                            values_path = Path("charts/django-app/values.yaml")
                            lines = values_path.read_text().splitlines()
                            image_section_found = False
                            image_tag_updated = False

                            for index, line in enumerate(lines):
                                if line == "image:":
                                    image_section_found = True
                                    continue

                                if image_section_found and line.startswith("  tag:"):
                                    lines[index] = f'  tag: "{os.environ["IMAGE_TAG"]}"'
                                    image_tag_updated = True
                                    break

                                if image_section_found and line and not line.startswith(" "):
                                    break

                            if not image_tag_updated:
                                raise SystemExit("Unable to update image.tag")

                            values_path.write_text(chr(10).join(lines) + chr(10))
                            PY

                            apt-get update
                            apt-get install -y --no-install-recommends git
                            rm -rf /var/lib/apt/lists/*
                            git config user.name "Jenkins"
                            git config user.email "jenkins@localhost"
                            git add charts/django-app/values.yaml
                            git commit -m "chore: deploy $IMAGE_TAG [skip ci]"
                            REPO_URL="$(git config --get remote.origin.url)"
                            AUTH_URL="https://${GIT_USERNAME}:${GIT_TOKEN}@${REPO_URL#https://}"
                            git push "$AUTH_URL" HEAD:main
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                if (env.SKIP_PIPELINE == 'true') {
                    echo 'Skipped Jenkins-authored GitOps commit.'
                } else {
                    echo "Published ${env.ECR_REPO}:${env.IMAGE_TAG}; Argo CD will sync the Git change."
                }
            }
        }
        failure {
            echo 'Pipeline failed - check stage logs above.'
        }
        always {
            container('docker') {
                sh 'docker system prune -f || true'
            }
        }
    }
}
